# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather and get your chat ID via @userinfobot
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Polymarket CLOB credentials ───────────────────────────────────────────────
# Generate from https://polymarket.com (Profile → API Keys)
POLY_PRIVATE_KEY=0x_your_polygon_wallet_private_key_here
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_polymarket_api_passphrase
POLY_CHAIN_ID=137

# ── Bot behaviour ─────────────────────────────────────────────────────────────
STARTING_CAPITAL=10000          # USD starting bankroll for Kelly sizing
MIN_TRADE_SIZE_USD=5000         # Only track whale trades >= this value
WIN_RATE_THRESHOLD=0.80         # Minimum win rate to follow a whale
GAME_CAP_PCT=0.07               # Max 7% of portfolio per game (across all positions in that game)
MIN_TRADES_ELIGIBLE=5           # Min WC trades before a wallet is eligible
POLL_INTERVAL_SECONDS=30        # How often to poll the CLOB API
PHASE_THRESHOLD=12              # Switch from collection → trading after this many games

# ── Safety ────────────────────────────────────────────────────────────────────
# Set to false ONLY when you are ready to place real money on Polymarket
DRY_RUN=true

# ── API ───────────────────────────────────────────────────────────────────────
CLOB_BASE_URL=https://clob.polymarket.com
